# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenvs
.venv/
venv/
env/

# Editor / agent metadata
.claude/
.codex
.vscode/
.idea/

# Local build / dist
build/
dist/

# Secrets — BLE pairing tokens, cached creds
*.token
.cuktech_ble.token

# Android bug reports (source data for RE, too large to track)
bugreport-*/

# Local scratch
test.py
scratch/
*.local.*

# Local helper scripts (deploy / pull / debug)
commit_push.sh
copy_files*.py
restart_ha.py
update_ha.py
update_hacs*.py

# Root-level patch / debug scratch (one-off fix attempts, never committed)
/patch_*.py
/disable_entry.py
/enable_entry.py
/list_entries.py
/payload.json
/scan.log

# tools/ scratch (one-off probes — long-lived utilities live here too,
# so gitignore is per-pattern not blanket)
/tools/test_*.py
/tools/add_strings.py
/tools/clean_coord.py
/tools/disable_ha*.py
/tools/enable_ha*.py
/tools/reload_ha*.py
/tools/get_ha_logs.py
/tools/query_hacs.py

# Other agent metadata kept out of the repo
GEMINI.md

# Tablet / charger screencaps (debugging artifacts)
screen*.png
/tmp/*.pcap

